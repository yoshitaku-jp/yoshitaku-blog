    "gatsby-plugin-react-helmet": "^3.9.0",
    "gatsby-source-filesystem": "^2.10.0",
    "gatsby-source-microcms": "^1.0.1",
    "gatsby-source-rss-feed": "^1.2.2",
    "gatsby-transformer-yaml": "^2.10.0",
    "minireset.css": "0.0.7",
    "react": "^16.14.0",
    "react-dom": "^16.14.0",
    "react-helmet": "^6.1.0"
  },
  "devDependencies": {
    "prettier": "2.1.2"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/gatsbyjs/gatsby-starter-hello-world"
